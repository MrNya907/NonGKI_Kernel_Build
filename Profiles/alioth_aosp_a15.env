CONFIG_ENV=Profiles/alioth_aosp_a15.env

DEVICE_NAME=Xiaomi MIX 4
DEVICE_CODENAME=odin

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
EXTRA_CMDS:NM=llvm-nm OBJDUMP=llvm-objdump STRIP=llvm-strip LLVM=1 LLVM_IAS=1 V=$VERBOSE
LD=ld.lld LLVM=1 LLVM_IAS=1 HOSTCC=gcc AS=llvm-as AR=llvm-ar NM=llvm-nm OBJCOPY=llvm-objcopy OBJDUMP=llvm-objdump STRIP=llvm-strip V=$VERBOSE

KERNEL_SOURCE=https://github.com/MrNya907/xiaomi_kernel_odin_mix4
KERNEL_BRANCH=master
CLANG_SOURCE=https://github.com/ruoqing501/clang-r383902b1.git
CLANG_BRANCH=

GCC_GNU=false
GCC_64_SOURCE=
GCC_64_BRANCH=
GCC_32_SOURCE=
GCC_32_BRANCH=

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=odin_defconfig
DEFCONFIG_ORIGIN_IMAGE=Image

KERNELSU_SOURCE=https://github.com/ShirkNeko/SukiSU-Ultra.git
KERNELSU_BRANCH=
KERNELSU_NAME=nongki

SUSFS_ENABLE=true
SUSFS_FIXED=true

AK3_SOURCE=https://github.com/osm0sis/AnyKernel3.git
AK3_BRANCH=master

BOOT_SOURCE=https://github.com/boot_author/android_kernel_codename/raw/refs/heads/main/rom/source_imgs/boot.img

LXC_ENABLE=true

HAVE_NO_DTBO=false

ROM_TEXT=aosp-fake
